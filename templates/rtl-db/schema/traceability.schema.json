{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Requirement-to-RTL traceability links",
  "type": "object",
  "required": ["links"],
  "additionalProperties": false,
  "properties": {
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["requirement_id", "db_entry", "status"],
        "additionalProperties": false,
        "properties": {
          "requirement_id": { "type": "string", "pattern": "^REQ-[0-9]{4,}$" },
          "db_entry": { "type": "string" },
          "rtl": { "type": "string" },
          "verification": { "type": "string" },
          "status": { "type": "string", "enum": ["in_progress", "covered", "uncovered", "conflict"] }
        }
      }
    }
  }
}
